# ============================================
# YouTube Trailer Automation - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- Google Cloud / YouTube ---
GOOGLE_CLIENT_SECRETS_FILE=client_secrets.json
GOOGLE_OAUTH_TOKEN_FILE=oauth_token.json
# YouTube Channel ID where trailers will be re-uploaded
YOUTUBE_CHANNEL_ID=
# Comma-separated list of YouTube channel IDs to monitor for new trailers
MONITORED_CHANNEL_IDS=UCqFzWgSCyM-gFsvZLKhH2yg,UCvC4D8iUCoK1sPGKL_eYiaA

# --- Google Drive ---
GOOGLE_DRIVE_FOLDER_ID=

# --- Gemini AI ---
GEMINI_API_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- GitHub (for GitHub Actions) ---
GH_PAT=

# --- Upload Settings ---
MAX_DAILY_UPLOADS=5
# Upload time windows in IST (comma-separated hours)
UPLOAD_TIME_WINDOWS=9,12,15,18,21

# --- FFmpeg Copyright Protection ---
# Mirror flip (horizontal)
FFMPEG_MIRROR=true
# Speed modification (1.0 = normal, 1.05 = 5% faster)
FFMPEG_SPEED=1.05
# Crop percentage from each side (e.g., 3 = 3% crop from all sides)
FFMPEG_CROP_PERCENT=3
# Color adjustment (brightness, contrast, saturation adjustments)
FFMPEG_BRIGHTNESS=0.02
FFMPEG_CONTRAST=1.02
FFMPEG_SATURATION=1.03

# --- Paths ---
DOWNLOAD_DIR=./downloads
PROCESSED_DIR=./processed
BACKUP_DIR=./backups
LOG_DIR=./logs
STATE_FILE=./data/state.json
